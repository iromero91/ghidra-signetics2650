@node ANDZ "ANDZ"

@{b}AND TO REGISTER ZERO@{ub}

@{b}Addressing Mode:@{ub}                Register
@{b}Size:@{ub}                           1 byte
@{b}Signetics Mnemonic:@{ub}             ANDZ r
@{b}CALM Mnemonic:@{ub}                  AND  A,reg
@{b}IEEE-694 Mnemonic:@{ub}              AND  .0,reg
