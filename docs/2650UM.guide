                                JUMP,EQ \@abs or JUMP,AO \@abs
                                JUMP,GT abs
                                JUMP,GT \@abs
                                JUMP,LT abs or JUMP,NO abs
                                JUMP,LT \@abs or JUMP,NO \@abs
                                JUMP    abs
                                JUMP    \@abs
