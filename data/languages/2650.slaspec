# RRR,r: rotate register right.
# Encoding: 010100rr  ($50-$53)
:RRR reg is op=0x14 & reg {
  local old:1 = reg;
  local oldc:1 = c;

  if (wc != 0) goto <rrr_wc_on>;

  # WC=0: pure 8-bit rotate, C/IDC unchanged.
  local wrap:1 = old << 7;
  reg = (old >> 1) | wrap;
  goto <rrr_rot_done>;

<rrr_wc_on>
  # WC=1: 9-bit rotate through C.
  local outc:1 = old & 1;
  reg = (old >> 1) | (oldc << 7);
  c = outc;
  idc = (old >> 6) & 1;

<rrr_rot_done>
  # OVF set if sign bit changed by rotate, else clear.
  if ((old s< 0) != (reg s< 0)) goto <rrr_ovf_yes>;
  ovf = 0;
  goto <rrr_ovf_done>;
<rrr_ovf_yes>
  ovf = 1;
<rrr_ovf_done>

  set_cc(reg);
}

# RRL,r: rotate register left.
# Encoding: 110100rr  ($D0-$D3)
:RRL reg is op=0x34 & reg {
  local old:1 = reg;
  local oldc:1 = c;

  if (wc != 0) goto <rrl_wc_on>;

  # WC=0: pure 8-bit rotate, C/IDC unchanged.
  local wrap:1 = old >> 7;
  reg = (old << 1) | wrap;
  goto <rrl_rot_done>;

<rrl_wc_on>
  # WC=1: 9-bit rotate through C.
  local outc:1 = old >> 7;
  reg = (old << 1) | oldc;
  c = outc;
  idc = (old >> 4) & 1;

<rrl_rot_done>
  # OVF set if sign bit changed by rotate, else clear.
  if ((old s< 0) != (reg s< 0)) goto <rrl_ovf_yes>;
  ovf = 0;
  goto <rrl_ovf_done>;
<rrl_ovf_yes>
  ovf = 1;
<rrl_ovf_done>

  set_cc(reg);
}

# DAR,r: decimal adjust register.
# Encoding: 100101rr  ($94-$97)
# Adds $AA/$A0/$0A/$00 based on C and IDC bits. C and IDC are not changed.
# CC is set to a meaningless value per the manual; we set it normally.
:DAR reg is op=0x25 & reg {
  local adj:1 = 0xAA;
  if (c != 0) goto <c_set>;
  if (idc != 0) goto <idc_set_c0>;
  # C=0, IDC=0 → add $AA (adj already set)
  goto <do_adj>;
<idc_set_c0>
  # C=0, IDC=1 → add $A0
  adj = 0xA0;
  goto <do_adj>;
<c_set>
  if (idc != 0) goto <both_set>;
  # C=1, IDC=0 → add $0A
  adj = 0x0A;
  goto <do_adj>;
<both_set>
  # C=1, IDC=1 → add $00 (no change)
  adj = 0x00;
<do_adj>
  reg = reg + adj;
  set_cc(reg);
}


## Branch operations

# BCTR,v rel: branch on condition true, relative.
# Encoding: 000110vv iaaaaaaa  ($18-$1B)

# BCTR,eq rel
:BCTR "eq, "^RELDST is byte=0x18; RELDST {
  if (cc1 != 0) goto <done>;
  if (cc0 != 0) goto <done>;
  iar = &RELDST;
  goto RELDST;
<done>
}

# BCTR,gt rel
:BCTR "gt, "^RELDST is byte=0x19; RELDST {
  if (cc1 != 0) goto <done>;
  if (cc0 == 0) goto <done>;
  iar = &RELDST;
  goto RELDST;
<done>
}

# BCTR,lt rel
:BCTR "lt, "^RELDST is byte=0x1a; RELDST {
  if (cc1 == 0) goto <done>;
  if (cc0 != 0) goto <done>;
  iar = &RELDST;
  goto RELDST;
<done>
}

# BCTR,un rel
:BCTR "un, "^RELDST is byte=0x1b; RELDST {
  iar = &RELDST;
  goto RELDST;
}

# BCTR,eq *rel
:BCTR "eq, "^RELINDDST is byte=0x18; RELINDDST {
  if (cc1 != 0) goto <done>;
  if (cc0 != 0) goto <done>;
  goto [RELINDDST];
<done>
}

# BCTR,gt *rel
:BCTR "gt, "^RELINDDST is byte=0x19; RELINDDST {
  if (cc1 != 0) goto <done>;
  if (cc0 == 0) goto <done>;
  goto [RELINDDST];
<done>
}

# BCTR,lt *rel
:BCTR "lt, "^RELINDDST is byte=0x1a; RELINDDST {
  if (cc1 == 0) goto <done>;
  if (cc0 != 0) goto <done>;
  goto [RELINDDST];
<done>
}

# BCTR,un *rel
:BCTR "un, "^RELINDDST is byte=0x1b; RELINDDST {
  goto [RELINDDST];
}

# BCTA,v abs: branch on condition true, absolute.
# Encoding: 000111vv ippaaaaa aaaaaaaa  ($1C-$1F)

# BCTA,eq abs
:BCTA "eq, "^BRABSDST is byte=0x1c; BRABSDST {
  if (cc1 != 0) goto <done>;
  if (cc0 != 0) goto <done>;
  local pgbits:2 = BRABSDST >> 13;
  page_latch = pgbits:1;
  goto BRABSDST;
<done>
}

# BCTA,gt abs
:BCTA "gt, "^BRABSDST is byte=0x1d; BRABSDST {
  if (cc1 != 0) goto <done>;
  if (cc0 == 0) goto <done>;
  local pgbits:2 = BRABSDST >> 13;
  page_latch = pgbits:1;
  goto BRABSDST;
<done>
}

# BCTA,lt abs
:BCTA "lt, "^BRABSDST is byte=0x1e; BRABSDST {
  if (cc1 == 0) goto <done>;
  if (cc0 != 0) goto <done>;
  local pgbits:2 = BRABSDST >> 13;
  page_latch = pgbits:1;
  goto BRABSDST;
<done>
}

# BCTA,un abs
:BCTA "un, "^BRABSDST is byte=0x1f; BRABSDST {
  local pgbits:2 = BRABSDST >> 13;
  page_latch = pgbits:1;
  goto BRABSDST;
}

# BCTA,eq *abs
:BCTA "eq, "^BRABSINDDST is byte=0x1c; BRABSINDDST {
  if (cc1 != 0) goto <done>;
  if (cc0 != 0) goto <done>;
  local pgbits:2 = BRABSINDDST >> 13;
  page_latch = pgbits:1;
  goto [BRABSINDDST];
<done>
}

# BCTA,gt *abs
:BCTA "gt, "^BRABSINDDST is byte=0x1d; BRABSINDDST {
  if (cc1 != 0) goto <done>;
  if (cc0 == 0) goto <done>;
  local pgbits:2 = BRABSINDDST >> 13;
  page_latch = pgbits:1;
  goto [BRABSINDDST];
<done>
}

# BCTA,lt *abs
:BCTA "lt, "^BRABSINDDST is byte=0x1e; BRABSINDDST {
  if (cc1 == 0) goto <done>;
  if (cc0 != 0) goto <done>;
  local pgbits:2 = BRABSINDDST >> 13;
  page_latch = pgbits:1;
  goto [BRABSINDDST];
<done>
}

# BCTA,un *abs
:BCTA "un, "^BRABSINDDST is byte=0x1f; BRABSINDDST {
  local pgbits:2 = BRABSINDDST >> 13;
  page_latch = pgbits:1;
  goto [BRABSINDDST];
}

# BCFR,v rel: branch on condition FALSE, relative.
# Encoding: 100110vv iaaaaaaa  ($98-$9A; $9B is ZBRR)
# Branch taken when CC does NOT match v.

# BCFR,eq rel  (branch if CC != eq)
:BCFR "eq, "^RELDST is byte=0x98; RELDST {
  if (cc1 != 0) goto <take>;
  if (cc0 == 0) goto <done>;
<take>
  goto RELDST;
<done>
}

# BCFR,gt rel  (branch if CC != gt)
:BCFR "gt, "^RELDST is byte=0x99; RELDST {
  if (cc1 != 0) goto <take>;
  if (cc0 != 0) goto <done>;
<take>
  goto RELDST;
<done>
}

# BCFR,lt rel  (branch if CC != lt)
:BCFR "lt, "^RELDST is byte=0x9a; RELDST {
  if (cc1 == 0) goto <take>;
  if (cc0 == 0) goto <done>;
<take>
  goto RELDST;
<done>
}

# BCFR,eq *rel
:BCFR "eq, "^RELINDDST is byte=0x98; RELINDDST {
  if (cc1 != 0) goto <take>;
  if (cc0 == 0) goto <done>;
<take>
  goto [RELINDDST];
<done>
}

# BCFR,gt *rel
:BCFR "gt, "^RELINDDST is byte=0x99; RELINDDST {
  if (cc1 != 0) goto <take>;
  if (cc0 != 0) goto <done>;
<take>
  goto [RELINDDST];
<done>
}

# BCFR,lt *rel
:BCFR "lt, "^RELINDDST is byte=0x9a; RELINDDST {
  if (cc1 == 0) goto <take>;
  if (cc0 == 0) goto <done>;
<take>
  goto [RELINDDST];
<done>
}

# BCFA,v abs: branch on condition FALSE, absolute.
# Encoding: 100111vv ippaaaaa aaaaaaaa  ($9C-$9E; $9F is BXA)
# Branch taken when CC does NOT match v. Taken branches update the page latch
# from the encoded destination page bits.

# BCFA,eq abs  (branch if CC != eq)
:BCFA "eq, "^BRABSDST is byte=0x9c; BRABSDST {
  if (cc1 != 0) goto <take>;
  if (cc0 == 0) goto <done>;
<take>
  local pgbits:2 = BRABSDST >> 13;
  page_latch = pgbits:1;
  goto BRABSDST;
<done>
}

# BCFA,gt abs  (branch if CC != gt)
:BCFA "gt, "^BRABSDST is byte=0x9d; BRABSDST {
  if (cc1 != 0) goto <take>;
  if (cc0 != 0) goto <done>;
<take>
  local pgbits:2 = BRABSDST >> 13;
  page_latch = pgbits:1;
  goto BRABSDST;
<done>
}

# BCFA,lt abs  (branch if CC != lt)
:BCFA "lt, "^BRABSDST is byte=0x9e; BRABSDST {
  if (cc1 == 0) goto <take>;
  if (cc0 == 0) goto <done>;
<take>
  local pgbits:2 = BRABSDST >> 13;
  page_latch = pgbits:1;
  goto BRABSDST;
<done>
}

# BCFA,eq *abs
:BCFA "eq, "^BRABSINDDST is byte=0x9c; BRABSINDDST {
  if (cc1 != 0) goto <take>;
  if (cc0 == 0) goto <done>;
<take>
  local pgbits:2 = BRABSINDDST >> 13;
  page_latch = pgbits:1;
  goto [BRABSINDDST];
<done>
}

# BCFA,gt *abs
:BCFA "gt, "^BRABSINDDST is byte=0x9d; BRABSINDDST {
  if (cc1 != 0) goto <take>;
  if (cc0 != 0) goto <done>;
<take>
  local pgbits:2 = BRABSINDDST >> 13;
  page_latch = pgbits:1;
  goto [BRABSINDDST];
<done>
}

# BCFA,lt *abs
:BCFA "lt, "^BRABSINDDST is byte=0x9e; BRABSINDDST {
  if (cc1 == 0) goto <take>;
  if (cc0 == 0) goto <done>;
<take>
  local pgbits:2 = BRABSINDDST >> 13;
  page_latch = pgbits:1;
  goto [BRABSINDDST];
<done>
}

# BXA abs,r3: branch indexed, absolute.
# Encoding: 10011111 ippaaaaa aaaaaaaa  ($9F)
# Unconditional; r3 is always the index. The encoded page bits select the base
# page and also update the page latch.

# BXA abs,r3
:BXA absaddr",r3" is byte=0x9f; ind_abs=0 & idx_ctrl & ahigh & alow
    [ absaddr = (idx_ctrl << 13) | (ahigh << 8) | alow; ] {
  page_latch = idx_ctrl:1;
  local base:2 = (ahigh << 8) | alow;
  local target:2 = base + zext(r3);
  goto [target];
}

# BXA *abs,r3
:BXA "*"^absaddr",r3" is byte=0x9f; ind_abs=1 & idx_ctrl & ahigh & alow
    [ absaddr = (idx_ctrl << 13) | (ahigh << 8) | alow; ] {
  page_latch = idx_ctrl:1;
  local ea:2 = (zext(page_latch:1) << 13) | (ahigh << 8) | alow;
  local base:2 = *[ram]:2 ea;
  local target:2 = base + zext(r3);
  goto [target];
}

# ZBRR: zero branch, relative.
# Encoding: 10011011 iaaaaaaa  ($9B)
# Target = signed displacement from address 0, masked to 13 bits (page bits cleared).

# ZBRR zero
:ZBRR ZERODST is byte=0x9b; ZERODST {
  goto ZERODST;
}

# ZBRR *zero
:ZBRR ZEROINDDST is byte=0x9b; ZEROINDDST {
  goto [ZEROINDDST];
}

# BRNR,r rel: branch on register non-zero, relative.
# Encoding: 010110rr iaaaaaaa  ($58-$5B)

# BRNR,r rel
:BRNR reg, RELDST is op=0x16 & reg; RELDST {
  if (reg == 0) goto <done>;
  goto RELDST;
<done>
}

# BRNR,r *rel
:BRNR reg, RELINDDST is op=0x16 & reg; RELINDDST {
  if (reg == 0) goto <done>;
  goto [RELINDDST];
<done>
}

# BRNA,r abs: branch on register non-zero, absolute.
# Encoding: 010111rr ippaaaaa aaaaaaaa  ($5C-$5F)
# Taken branches use the encoded destination page and update the page latch.

# BRNA,r abs
:BRNA reg, BRABSDST is op=0x17 & reg; BRABSDST {
  if (reg == 0) goto <done>;
  goto BRABSDST;
<done>
}

# BRNA,r *abs
:BRNA reg, BRABSINDDST is op=0x17 & reg; BRABSINDDST {
  if (reg == 0) goto <done>;
  goto [BRABSINDDST];
<done>
}

# BIRR,r rel: branch on incrementing register, relative.
# Encoding: 110110rr iaaaaaaa  ($D8-$DB)

# BIRR,r rel
:BIRR reg, RELDST is op=0x36 & reg; RELDST {
  reg = reg + 1;
  if (reg == 0) goto <done>;
  goto RELDST;
<done>
}

# BIRR,r *rel
:BIRR reg, RELINDDST is op=0x36 & reg; RELINDDST {
  reg = reg + 1;
  if (reg == 0) goto <done>;
  goto [RELINDDST];
<done>
}

# BIRA,r abs: branch on incrementing register, absolute.
# Encoding: 110111rr ippaaaaa aaaaaaaa  ($DC-$DF)
# Taken branches use the encoded destination page and update the page latch.

# BIRA,r abs
:BIRA reg, BRABSDST is op=0x37 & reg; BRABSDST {
  reg = reg + 1;
  if (reg == 0) goto <done>;
  local pgbits:2 = BRABSDST >> 13;
  page_latch = pgbits:1;
  goto BRABSDST;
<done>
}

# BIRA,r *abs
:BIRA reg, BRABSINDDST is op=0x37 & reg; BRABSINDDST {
  reg = reg + 1;
  if (reg == 0) goto <done>;
  local pgbits:2 = BRABSINDDST >> 13;
  page_latch = pgbits:1;
  goto [BRABSINDDST];
<done>
}

# BDRR,r rel: branch on decrementing register, relative.
# Encoding: 111110rr iaaaaaaa  ($F8-$FB)

# BDRR,r rel
:BDRR reg, RELDST is op=0x3e & reg; RELDST {
  reg = reg - 1;
  if (reg != 0) goto RELDST;
}

# BDRR,r *rel
:BDRR reg, RELINDDST is op=0x3e & reg; RELINDDST {
  reg = reg - 1;
  if (reg == 0) goto <done>;
  goto [RELINDDST];
<done>
}

# BDRA,r abs: branch on decrementing register, absolute.
# Encoding: 111111rr ippaaaaa aaaaaaaa  ($FC-$FF)
# Taken branches use the encoded destination page and update the page latch.

# BDRA,r abs
:BDRA reg, BRABSDST is op=0x3f & reg; BRABSDST {
  reg = reg - 1;
  if (reg != 0) goto <branch>;
  goto <done>;
<branch>
  local pgbits:2 = BRABSDST >> 13;
  page_latch = pgbits:1;
  goto BRABSDST;
<done>
}

# BDRA,r *abs
:BDRA reg, BRABSINDDST is op=0x3f & reg; BRABSINDDST {
  reg = reg - 1;
  if (reg == 0) goto <done>;
  local pgbits:2 = BRABSINDDST >> 13;
  page_latch = pgbits:1;
  goto [BRABSINDDST];
<done>
}


## Subroutine branch operations
# Subroutine calls push the return address onto the hardware Return Address Stack (RAS).
# Modeled with SLEIGH 'call' which generates CALLIND p-code.

# BSTR,v rel: branch to subroutine on condition true, relative.
# Encoding: 001110vv iaaaaaaa  ($38-$3B)

# BSTR,eq rel
:BSTR "eq, "^RELDST is byte=0x38; RELDST {
  if (cc1 != 0) goto <done>;
  if (cc0 != 0) goto <done>;
  call RELDST;
<done>
}

# BSTR,gt rel
:BSTR "gt, "^RELDST is byte=0x39; RELDST {
  if (cc1 != 0) goto <done>;
  if (cc0 == 0) goto <done>;
  call RELDST;
<done>
}

# BSTR,lt rel
:BSTR "lt, "^RELDST is byte=0x3a; RELDST {
  if (cc1 == 0) goto <done>;
  if (cc0 != 0) goto <done>;
  call RELDST;
<done>
}

# BSTR,un rel
:BSTR "un, "^RELDST is byte=0x3b; RELDST {
  call RELDST;
}

# BSTR,eq *rel
:BSTR "eq, "^RELINDDST is byte=0x38; RELINDDST {
  if (cc1 != 0) goto <done>;
  if (cc0 != 0) goto <done>;
  call [RELINDDST];
<done>
}

# BSTR,gt *rel
:BSTR "gt, "^RELINDDST is byte=0x39; RELINDDST {
  if (cc1 != 0) goto <done>;
  if (cc0 == 0) goto <done>;
  call [RELINDDST];
<done>
}

# BSTR,lt *rel
:BSTR "lt, "^RELINDDST is byte=0x3a; RELINDDST {
  if (cc1 == 0) goto <done>;
  if (cc0 != 0) goto <done>;
  call [RELINDDST];
<done>
}

# BSTR,un *rel
:BSTR "un, "^RELINDDST is byte=0x3b; RELINDDST {
  call [RELINDDST];
}

# BSTA,v abs: branch to subroutine on condition true, absolute.
# Encoding: 001111vv ippaaaaa aaaaaaaa  ($3C-$3F)
# Taken calls use the encoded destination page and update the page latch.

# BSTA,eq abs
:BSTA "eq, "^BRABSDST is byte=0x3c; BRABSDST {
  if (cc1 != 0) goto <done>;
  if (cc0 != 0) goto <done>;
  local pgbits:2 = BRABSDST >> 13;
  page_latch = pgbits:1;
  call BRABSDST;
<done>
}

# BSTA,gt abs
:BSTA "gt, "^BRABSDST is byte=0x3d; BRABSDST {
  if (cc1 != 0) goto <done>;
  if (cc0 == 0) goto <done>;
  local pgbits:2 = BRABSDST >> 13;
  page_latch = pgbits:1;
  call BRABSDST;
<done>
}

# BSTA,lt abs
:BSTA "lt, "^BRABSDST is byte=0x3e; BRABSDST {
  if (cc1 == 0) goto <done>;
  if (cc0 != 0) goto <done>;
  local pgbits:2 = BRABSDST >> 13;
  page_latch = pgbits:1;
  call BRABSDST;
<done>
}

# BSTA,un abs
:BSTA "un, "^BRABSDST is byte=0x3f; BRABSDST {
  local pgbits:2 = BRABSDST >> 13;
  page_latch = pgbits:1;
  call BRABSDST;
}

# BSTA,eq *abs
:BSTA "eq, "^BRABSINDDST is byte=0x3c; BRABSINDDST {
  if (cc1 != 0) goto <done>;
  if (cc0 != 0) goto <done>;
  local pgbits:2 = BRABSINDDST >> 13;
  page_latch = pgbits:1;
  call [BRABSINDDST];
<done>
}

# BSTA,gt *abs
