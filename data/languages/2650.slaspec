define endian=big;
define alignment=1;

define space ram type=ram_space size=2 default;
define space register type=register_space size=2;
define space io type=ram_space size=1;

# Decompiler-facing I/O intrinsics for external bus access.
define pcodeop io_read;
define pcodeop io_write;

define register offset=0x00 size=1 [ r0 r1 r2 r3 r1p r2p r3p ir hr psu psl ];
define register offset=0x20 size=2 [ iar oar ras0 ras1 ras2 ras3 ras4 ras5 ras6 ras7 ];
define register offset=0x30 size=1 [ page_latch ];

define bitrange cc1 = psl[7,1];
define bitrange cc0 = psl[6,1];
define bitrange idc = psl[5,1];
define bitrange rs  = psl[4,1];
define bitrange wc  = psl[3,1];
define bitrange ovf = psl[2,1];
define bitrange com = psl[1,1];
define bitrange c   = psl[0,1];
define bitrange ii  = psu[3,1];

# Page-latch context: holds the current page bits (ADR14:ADR13).
# Set by branch/call instructions; defaults to page 0 at RESET.
# Non-branch memory accesses use this to form full 15-bit effective addresses.
define context
  page_latch
;

macro swap_rs_banks() {
  local t1:1 = r1;
  local t2:1 = r2;
  local t3:1 = r3;
  r1 = r1p;
  r2 = r2p;
  r3 = r3p;
  r1p = t1;
  r2p = t2;
  r3p = t3;
}

macro set_cc(val) {
  local is_neg:1 = (val s< 0);
  local is_nz:1 = (val != 0);
  cc1 = is_neg;
  cc0 = is_nz & ~is_neg;
}

macro add8_set_flags(dst, src) {
  local cin:1 = 0;
  if (wc != 0) goto <wc_on>;
  goto <wc_done>;
<wc_on>
  cin = c;
<wc_done>

  local a:1 = dst;
  local b:1 = src;
  local aw:2 = zext(a);
  local bw:2 = zext(b);
  local ciw:2 = zext(cin);

  local sum:2 = aw + bw + ciw;
  local res:1 = sum:1;
  dst = res;

  if ((sum >> 8) == 0) goto <c_zero>;
  c = 1;
  goto <c_done>;
<c_zero>
  c = 0;
<c_done>

  local nibsum:2 = (aw & 0xf) + (bw & 0xf) + ciw;
  if ((nibsum >> 4) == 0) goto <idc_zero>;
  idc = 1;
  goto <idc_done>;
<idc_zero>
  idc = 0;
<idc_done>

  if ((a s< 0) != (b s< 0)) goto <ovf_no>;
  if ((res s< 0) != (a s< 0)) goto <ovf_yes>;
<ovf_no>
  ovf = 0;
  goto <ovf_done>;
<ovf_yes>
  ovf = 1;
<ovf_done>

  set_cc(res);
}

macro sub8_set_flags(dst, src) {
  local bin:1 = 0;
  if (wc != 0) goto <wc_on>;
  goto <wc_done>;
<wc_on>
  if (c != 0) goto <carry_set>;
  bin = 1;
  goto <wc_done>;
<carry_set>
  bin = 0;
<wc_done>

  local a:1 = dst;
  local b:1 = src;
  local aw:2 = zext(a);
  local bw:2 = zext(b);
  local biw:2 = zext(bin);

  local diff:2 = aw - bw - biw;
  local res:1 = diff:1;
  dst = res;

  local subtr:2 = bw + biw;
  if (aw < subtr) goto <borrow_yes>;
  c = 1;
  goto <c_done>;
<borrow_yes>
  c = 0;
<c_done>

  local an:2 = aw & 0xf;
  local bn:2 = bw & 0xf;
  local subn:2 = bn + biw;
  if (an < subn) goto <idc_borrow_yes>;
  idc = 1;
  goto <idc_done>;
<idc_borrow_yes>
  idc = 0;
<idc_done>

  if ((a s< 0) == (b s< 0)) goto <ovf_no>;
  if ((res s< 0) != (a s< 0)) goto <ovf_yes>;
<ovf_no>
  ovf = 0;
  goto <ovf_done>;
<ovf_yes>
  ovf = 1;
<ovf_done>

  set_cc(res);
}

macro and8_set_cc(dst, src) {
  dst = dst & src;
  set_cc(dst);
}

macro eor8_set_cc(dst, src) {
  dst = dst ^ src;
  set_cc(dst);
}

macro ior8_set_cc(dst, src) {
  dst = dst | src;
  set_cc(dst);
}

macro set_cc_compare(lhs, rhs) {
  if (lhs == rhs) goto <cmp_eq>;

  # COM=1 -> logical (unsigned) compare, COM=0 -> arithmetic (signed) compare.
  if (com != 0) goto <cmp_logical>;
  if (lhs s< rhs) goto <cmp_lt>;
  goto <cmp_gt>;

<cmp_logical>
  if (lhs < rhs) goto <cmp_lt>;
  goto <cmp_gt>;

<cmp_eq>
  cc1 = 0;
  cc0 = 0;
  goto <cmp_done>;

<cmp_lt>
  cc1 = 1;
  cc0 = 0;
  goto <cmp_done>;

<cmp_gt>
  cc1 = 0;
  cc0 = 1;

<cmp_done>
}

macro set_cc_test_under_mask(val, mask) {
  local t:1 = val & mask;
  if (t == mask) goto <tmi_eq>;
  cc1 = 1;
  cc0 = 0;
  goto <tmi_done>;
<tmi_eq>
  cc1 = 0;
  cc0 = 0;
<tmi_done>
}


define token instr8 (8)
  byte = (0,7)
  op  = (2,7)
  reg = (0,1)
;

# Absolute-address extension token for *A forms (bytes 1+2 as 16-bit BE):
# byte1 = iccaaaaa (HIGH byte in big-endian token), byte2 = aaaaaaaa (LOW byte)
define token absaddr_tok (16)
  ind_abs  = (15,15)  # indirect flag (bit 7 of byte1)
  idx_ctrl = (13,14)  # 0=none, 1=pre-inc, 2=pre-dec, 3=index-only (bits 6-5 of byte1)
  ahigh    = (8,12)   # addr[12:8] (bits 4-0 of byte1)
  alow     = (0,7)    # addr[7:0]  (byte2)
;

# Absolute branch/call instructions use ippaaaaa aaaaaaaa format, where:
# - i (bit 15) is the indirect flag
# - pp (bits 14-13) are the page bits that set ADR14:ADR13
# - aaa (bits 12-0) are the 13-bit address within the target page
define token absflow_tok (16)
  flow_ind  = (15,15)   # indirect flag
  flow_page = (13,14)   # page bits [14:13] for ADR14:ADR13
  flow_addr = (0,12)    # address within page [12:0]
;

define token imm8_tok (8)
  imm8 = (0,7)
;

define token reladdr_tok (8)
  ind  = (7,7)
  rel7 = (0,6) signed
;

attach variables [ reg ] [ r0 r1 r2 r3 ];

# Direct branch/call destinations are exported as address operands so Ghidra can
# recover direct control-flow edges instead of seeing them as computed indirects.
RELDST: reladdr is ind=0 & rel7 [ reladdr = inst_next + rel7; ] {
  export *:2 reladdr;
}
RELINDDST: "*"^reladdr is ind=1 & rel7 [ reladdr = inst_next + rel7; ] {
  export *[ram]:2 reladdr;
}

BRABSDST: absflow is flow_ind=0 & flow_page & flow_addr 
    [ absflow = (flow_page << 13) | flow_addr; ] {
  export *:2 absflow;
}
BRABSINDDST: "*"^absflow is flow_ind=1 & flow_page & flow_addr 
    [ absflow = (flow_page << 13) | flow_addr; ] {
  export *[ram]:2 absflow;
}

# Absolute data operands are 13-bit in the encoding. For display/references,
# qualify them with the current instruction page so non-page0 listings are
# rendered with page-local labels.
ABSDATADST: absaddr is ind_abs=0 & idx_ctrl & ahigh & alow
    [ absaddr = ((inst_start >> 13) << 13) | (ahigh << 8) | alow; ] {
  export *:2 absaddr;
}
ABSDATAINDDST: "*"^absaddr is ind_abs=1 & idx_ctrl & ahigh & alow
    [ absaddr = ((inst_start >> 13) << 13) | (ahigh << 8) | alow; ] {
  export *[ram]:2 absaddr;
}

ZERODST: reladdr is ind=0 & rel7 [ reladdr = rel7 & 0x1fff; ] {
  local target:2 = sext(rel7:1) & 0x1fff;
  export *:2 target;
}
ZEROINDDST: "*"^reladdr is ind=1 & rel7 [ reladdr = rel7 & 0x1fff; ] {
  local ea:2 = sext(rel7:1) & 0x1fff;
  export *[ram]:2 ea;
}

# NOP instruction
:NOP is byte=0xc0 { r0 = r0; }

# HALT instruction (WAIT state)
:HALT is byte=0x40 unimpl

## Load and Store operations

# 0x00 is explicitly indeterminate on 2650 and not a valid LODZ form.
:ILL_00 is byte=0x00 unimpl

# LODZ r: valid in hardware for r1..r3 only. The explicit ILL_00 constructor
# handles the forbidden r0 encoding while this generic form covers 0x01..0x03.
:LODZ reg is op=0x00 & reg {
  r0 = reg;
  set_cc(r0);
}

# LODI,r v: Load immediate value into register r, set CC on result.
# Encoding: 000001rr vvvvvvvv  ($04-$07)
:LODI reg, imm8 is op=0x01 & reg; imm8 {
  reg = imm8:1;
  set_cc(reg);
}

# LODR,r rel: Load from PC-relative address, direct.
# Encoding: 000010rr 0aaaaaaa  ($08-$0B, i=0)
# EA = inst_next + sign_extend(rel7)
:LODR reg, reladdr is op=0x02 & reg; ind=0 & rel7 [ reladdr = inst_next + rel7; ] {
  local ea:2 = inst_next + rel7;
  reg = *[ram]:1 ea;
  set_cc(reg);
}

# LODR,r *rel: Load from PC-relative address, indirect.
# Encoding: 000010rr 1aaaaaaa  ($08-$0B, i=1)
# EA = *(inst_next + sign_extend(rel7))
:LODR reg, "*"^reladdr is op=0x02 & reg; ind=1 & rel7 [ reladdr = inst_next + rel7; ] {
  local ea:2 = inst_next + rel7;
  local indir:2 = *[ram]:2 ea;
  reg = *[ram]:1 indir;
  set_cc(reg);
}


# --- LODA (Load Absolute) ---
# 3 bytes: 000011rr iccaaaaa aaaaaaaa  ($0C-$0F)
# Direct absolute forms use the current instruction page for the high 2 bits;
# the encoded operand contributes the low 13 bits. Indirect forms fetch the
# pointer from the current page and then dereference the full 15-bit pointer.
# idx_ctrl=0: non-indexed, destination = reg
# idx_ctrl=1/2/3: indexed, destination forced to r0, reg is the index register

# Non-indexed direct: rn = *(abs)
:LODA reg, ABSDATADST is op=0x03 & reg; idx_ctrl=0 & ABSDATADST & ahigh & alow {
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  reg = *[ram]:1 ea;
  set_cc(reg);
}

# Non-indexed indirect: rn = *(*(abs))
:LODA reg, ABSDATAINDDST is op=0x03 & reg; idx_ctrl=0 & ABSDATAINDDST & ahigh & alow {
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  local indir:2 = *[ram]:2 ea;
  reg = *[ram]:1 indir;
  set_cc(reg);
}

# Indexed-only direct: r0 = *(abs + rn)
:LODA "r0, "^ABSDATADST^", "^reg is op=0x03 & reg; idx_ctrl=3 & ABSDATADST & ahigh & alow {
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  local idx:2 = zext(reg);
  r0 = *[ram]:1 (ea + idx);
  set_cc(r0);
}

# Indexed-only indirect: r0 = *(*(abs) + rn)
:LODA "r0, *"^ABSDATAINDDST^", "^reg is op=0x03 & reg; idx_ctrl=3 & ABSDATAINDDST & ahigh & alow {
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  local base:2 = *[ram]:2 ea;
  local idx:2 = zext(reg);
  r0 = *[ram]:1 (base + idx);
  set_cc(r0);
}

# Pre-increment direct: ++rn; r0 = *(abs + rn)
:LODA "r0, "^ABSDATADST^", "^reg^"+" is op=0x03 & reg; idx_ctrl=1 & ABSDATADST & ahigh & alow {
  reg = reg + 1;
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  local idx:2 = zext(reg);
  r0 = *[ram]:1 (ea + idx);
  set_cc(r0);
}

# Pre-increment indirect: ++rn; r0 = *(*(abs) + rn)
:LODA "r0, *"^ABSDATAINDDST^", "^reg^"+" is op=0x03 & reg; idx_ctrl=1 & ABSDATAINDDST & ahigh & alow {
  reg = reg + 1;
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  local base:2 = *[ram]:2 ea;
  local idx:2 = zext(reg);
  r0 = *[ram]:1 (base + idx);
  set_cc(r0);
}

# Pre-decrement direct: --rn; r0 = *(abs + rn)
:LODA "r0, "^ABSDATADST^", "^reg^"-" is op=0x03 & reg; idx_ctrl=2 & ABSDATADST & ahigh & alow {
  reg = reg - 1;
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  local idx:2 = zext(reg);
  r0 = *[ram]:1 (ea + idx);
  set_cc(r0);
}

# Pre-decrement indirect: --rn; r0 = *(*(abs) + rn)
:LODA "r0, *"^ABSDATAINDDST^", "^reg^"-" is op=0x03 & reg; idx_ctrl=2 & ABSDATAINDDST & ahigh & alow {
  reg = reg - 1;
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  local base:2 = *[ram]:2 ea;
  local idx:2 = zext(reg);
  r0 = *[ram]:1 (base + idx);
  set_cc(r0);
}

# STRZ r: store register zero into register r.
# The generic pattern includes 0xC0, but explicit NOP at 0xC0 is defined
# separately and should remain the selected decode for that opcode.
:STRZ reg is op=0x30 & reg {
  reg = r0;
  set_cc(reg);
}

# STRR,r rel: store register to PC-relative address, direct.
# Encoding: 110010rr 0aaaaaaa  ($C8-$CB, i=0)
:STRR reg, reladdr is op=0x32 & reg; ind=0 & rel7 [ reladdr = inst_next + rel7; ] {
  local ea:2 = inst_next + rel7;
  *[ram]:1 ea = reg;
}

# STRR,r *rel: store register to PC-relative indirect address.
# Encoding: 110010rr 1aaaaaaa  ($C8-$CB, i=1)
:STRR reg, "*"^reladdr is op=0x32 & reg; ind=1 & rel7 [ reladdr = inst_next + rel7; ] {
  local ea:2 = inst_next + rel7;
  local ptr:2 = *[ram]:2 ea;
  *[ram]:1 ptr = reg;
}

# --- STRA (Store Absolute) ---
# 3 bytes: 110011rr iccaaaaa aaaaaaaa  ($CC-$CF)
# idx_ctrl=0: source = reg
# idx_ctrl=1/2/3: indexed mode, source forced to r0 and reg is index register

# Non-indexed direct: *(abs) = rn
:STRA reg, ABSDATADST is op=0x33 & reg; idx_ctrl=0 & ABSDATADST & ahigh & alow {
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  *[ram]:1 ea = reg;
}

# Non-indexed indirect: *(*(abs)) = rn
:STRA reg, ABSDATAINDDST is op=0x33 & reg; idx_ctrl=0 & ABSDATAINDDST & ahigh & alow {
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  local ptr:2 = *[ram]:2 ea;
  *[ram]:1 ptr = reg;
}

# Indexed-only direct: *(abs + rn) = r0
:STRA "r0, "^ABSDATADST^", "^reg is op=0x33 & reg; idx_ctrl=3 & ABSDATADST & ahigh & alow {
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  local idx:2 = zext(reg);
  *[ram]:1 (ea + idx) = r0;
}

# Indexed-only indirect: *(*(abs) + rn) = r0
:STRA "r0, *"^ABSDATAINDDST^", "^reg is op=0x33 & reg; idx_ctrl=3 & ABSDATAINDDST & ahigh & alow {
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  local base:2 = *[ram]:2 ea;
  local idx:2 = zext(reg);
  *[ram]:1 (base + idx) = r0;
}

# Pre-increment direct: ++rn; *(abs + rn) = r0
:STRA "r0, "^ABSDATADST^", "^reg^"+" is op=0x33 & reg; idx_ctrl=1 & ABSDATADST & ahigh & alow {
  reg = reg + 1;
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  local idx:2 = zext(reg);
  *[ram]:1 (ea + idx) = r0;
}

# Pre-increment indirect: ++rn; *(*(abs) + rn) = r0
:STRA "r0, *"^ABSDATAINDDST^", "^reg^"+" is op=0x33 & reg; idx_ctrl=1 & ABSDATAINDDST & ahigh & alow {
  reg = reg + 1;
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  local base:2 = *[ram]:2 ea;
  local idx:2 = zext(reg);
  *[ram]:1 (base + idx) = r0;
}

# Pre-decrement direct: --rn; *(abs + rn) = r0
:STRA "r0, "^ABSDATADST^", "^reg^"-" is op=0x33 & reg; idx_ctrl=2 & ABSDATADST & ahigh & alow {
  reg = reg - 1;
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  local idx:2 = zext(reg);
  *[ram]:1 (ea + idx) = r0;
}

# Pre-decrement indirect: --rn; *(*(abs) + rn) = r0
:STRA "r0, *"^ABSDATAINDDST^", "^reg^"-" is op=0x33 & reg; idx_ctrl=2 & ABSDATAINDDST & ahigh & alow {
  reg = reg - 1;
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  local base:2 = *[ram]:2 ea;
  local idx:2 = zext(reg);
  *[ram]:1 (base + idx) = r0;
}


## Arithmetic operations

# ADDZ reg: add selected register to r0 and store in r0.
:ADDZ reg is op=0x20 & reg {
  add8_set_flags(r0, reg);
}

# ADDI,r v: add immediate value to register r.
# Encoding: 100001rr vvvvvvvv  ($84-$87)
:ADDI reg, imm8 is op=0x21 & reg; imm8 {
  add8_set_flags(reg, imm8:1);
}

# ADDR,r rel: add value at PC-relative address to register r (direct).
# Encoding: 100010rr 0aaaaaaa  ($88-$8B, i=0)
:ADDR reg, reladdr is op=0x22 & reg; ind=0 & rel7 [ reladdr = inst_next + rel7; ] {
  local ea:2 = inst_next + rel7;
  local m:1 = *[ram]:1 ea;
  add8_set_flags(reg, m);
}

# ADDR,r *rel: add value at PC-relative indirect address to register r.
# Encoding: 100010rr 1aaaaaaa  ($88-$8B, i=1)
:ADDR reg, "*"^reladdr is op=0x22 & reg; ind=1 & rel7 [ reladdr = inst_next + rel7; ] {
  local ea:2 = inst_next + rel7;
  local ptr:2 = *[ram]:2 ea;
  local m:1 = *[ram]:1 ptr;
  add8_set_flags(reg, m);
}

# --- ADDA (Add Absolute) ---
# 3 bytes: 100011rr iccaaaaa aaaaaaaa  ($8C-$8F)
# idx_ctrl=0: destination = reg
# idx_ctrl=1/2/3: indexed mode, destination forced to r0, reg is index register

# Non-indexed direct: rn += *(abs)
:ADDA reg, absaddr is op=0x23 & reg; ind_abs=0 & idx_ctrl=0 & ahigh & alow
    [ absaddr = (ahigh << 8) | alow; ] {
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  local m:1 = *[ram]:1 ea;
  add8_set_flags(reg, m);
}

# Non-indexed indirect: rn += *(*(abs))
:ADDA reg, "*"^absaddr is op=0x23 & reg; ind_abs=1 & idx_ctrl=0 & ahigh & alow
    [ absaddr = (ahigh << 8) | alow; ] {
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  local ptr:2 = *[ram]:2 ea;
  local m:1 = *[ram]:1 ptr;
  add8_set_flags(reg, m);
}

# Indexed-only direct: r0 += *(abs + rn)
:ADDA "r0, "^absaddr^", "^reg is op=0x23 & reg; ind_abs=0 & idx_ctrl=3 & ahigh & alow
    [ absaddr = (ahigh << 8) | alow; ] {
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  local idx:2 = zext(reg);
  local m:1 = *[ram]:1 (ea + idx);
  add8_set_flags(r0, m);
}

# Indexed-only indirect: r0 += *(*(abs) + rn)
:ADDA "r0, *"^absaddr^", "^reg is op=0x23 & reg; ind_abs=1 & idx_ctrl=3 & ahigh & alow
    [ absaddr = (ahigh << 8) | alow; ] {
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  local base:2 = *[ram]:2 ea;
  local idx:2 = zext(reg);
  local m:1 = *[ram]:1 (base + idx);
  add8_set_flags(r0, m);
}

# Pre-increment direct: ++rn; r0 += *(abs + rn)
:ADDA "r0, "^absaddr^", "^reg^"+" is op=0x23 & reg; ind_abs=0 & idx_ctrl=1 & ahigh & alow
    [ absaddr = (ahigh << 8) | alow; ] {
  reg = reg + 1;
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  local idx:2 = zext(reg);
  local m:1 = *[ram]:1 (ea + idx);
  add8_set_flags(r0, m);
}

# Pre-increment indirect: ++rn; r0 += *(*(abs) + rn)
:ADDA "r0, *"^absaddr^", "^reg^"+" is op=0x23 & reg; ind_abs=1 & idx_ctrl=1 & ahigh & alow
    [ absaddr = (ahigh << 8) | alow; ] {
  reg = reg + 1;
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  local base:2 = *[ram]:2 ea;
  local idx:2 = zext(reg);
  local m:1 = *[ram]:1 (base + idx);
  add8_set_flags(r0, m);
}

# Pre-decrement direct: --rn; r0 += *(abs + rn)
:ADDA "r0, "^absaddr^", "^reg^"-" is op=0x23 & reg; ind_abs=0 & idx_ctrl=2 & ahigh & alow
    [ absaddr = (ahigh << 8) | alow; ] {
  reg = reg - 1;
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  local idx:2 = zext(reg);
  local m:1 = *[ram]:1 (ea + idx);
  add8_set_flags(r0, m);
}

# Pre-decrement indirect: --rn; r0 += *(*(abs) + rn)
:ADDA "r0, *"^absaddr^", "^reg^"-" is op=0x23 & reg; ind_abs=1 & idx_ctrl=2 & ahigh & alow
    [ absaddr = (ahigh << 8) | alow; ] {
  reg = reg - 1;
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  local base:2 = *[ram]:2 ea;
  local idx:2 = zext(reg);
  local m:1 = *[ram]:1 (base + idx);
  add8_set_flags(r0, m);
}

# SUBZ reg: subtract selected register from r0.
# Encoding: 101000rr  ($A0-$A3)
:SUBZ reg is op=0x28 & reg {
  sub8_set_flags(r0, reg);
}

# SUBI,r v: subtract immediate value from register r.
# Encoding: 101001rr vvvvvvvv  ($A4-$A7)
:SUBI reg, imm8 is op=0x29 & reg; imm8 {
  sub8_set_flags(reg, imm8:1);
}

# SUBR,r rel: subtract value at PC-relative address from register r (direct).
# Encoding: 101010rr 0aaaaaaa  ($A8-$AB, i=0)
:SUBR reg, reladdr is op=0x2a & reg; ind=0 & rel7 [ reladdr = inst_next + rel7; ] {
  local ea:2 = inst_next + rel7;
  local m:1 = *[ram]:1 ea;
  sub8_set_flags(reg, m);
}

# SUBR,r *rel: subtract value at PC-relative indirect address from register r.
# Encoding: 101010rr 1aaaaaaa  ($A8-$AB, i=1)
:SUBR reg, "*"^reladdr is op=0x2a & reg; ind=1 & rel7 [ reladdr = inst_next + rel7; ] {
  local ea:2 = inst_next + rel7;
  local ptr:2 = *[ram]:2 ea;
  local m:1 = *[ram]:1 ptr;
  sub8_set_flags(reg, m);
}

# --- SUBA (Subtract Absolute) ---
# 3 bytes: 101011rr iccaaaaa aaaaaaaa  ($AC-$AF)
# idx_ctrl=0: destination = reg
# idx_ctrl=1/2/3: indexed mode, destination forced to r0, reg is index register

# Non-indexed direct: rn -= *(abs)
:SUBA reg, absaddr is op=0x2b & reg; ind_abs=0 & idx_ctrl=0 & ahigh & alow
    [ absaddr = (ahigh << 8) | alow; ] {
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  local m:1 = *[ram]:1 ea;
  sub8_set_flags(reg, m);
}

# Non-indexed indirect: rn -= *(*(abs))
:SUBA reg, "*"^absaddr is op=0x2b & reg; ind_abs=1 & idx_ctrl=0 & ahigh & alow
    [ absaddr = (ahigh << 8) | alow; ] {
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  local ptr:2 = *[ram]:2 ea;
  local m:1 = *[ram]:1 ptr;
  sub8_set_flags(reg, m);
}

# Indexed-only direct: r0 -= *(abs + rn)
:SUBA "r0, "^absaddr^", "^reg is op=0x2b & reg; ind_abs=0 & idx_ctrl=3 & ahigh & alow
    [ absaddr = (ahigh << 8) | alow; ] {
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  local idx:2 = zext(reg);
  local m:1 = *[ram]:1 (ea + idx);
  sub8_set_flags(r0, m);
}

# Indexed-only indirect: r0 -= *(*(abs) + rn)
:SUBA "r0, *"^absaddr^", "^reg is op=0x2b & reg; ind_abs=1 & idx_ctrl=3 & ahigh & alow
    [ absaddr = (ahigh << 8) | alow; ] {
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  local base:2 = *[ram]:2 ea;
  local idx:2 = zext(reg);
  local m:1 = *[ram]:1 (base + idx);
  sub8_set_flags(r0, m);
}

# Pre-increment direct: ++rn; r0 -= *(abs + rn)
:SUBA "r0, "^absaddr^", "^reg^"+" is op=0x2b & reg; ind_abs=0 & idx_ctrl=1 & ahigh & alow
    [ absaddr = (ahigh << 8) | alow; ] {
  reg = reg + 1;
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  local idx:2 = zext(reg);
  local m:1 = *[ram]:1 (ea + idx);
  sub8_set_flags(r0, m);
}

# Pre-increment indirect: ++rn; r0 -= *(*(abs) + rn)
:SUBA "r0, *"^absaddr^", "^reg^"+" is op=0x2b & reg; ind_abs=1 & idx_ctrl=1 & ahigh & alow
    [ absaddr = (ahigh << 8) | alow; ] {
  reg = reg + 1;
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  local base:2 = *[ram]:2 ea;
  local idx:2 = zext(reg);
  local m:1 = *[ram]:1 (base + idx);
  sub8_set_flags(r0, m);
}

# Pre-decrement direct: --rn; r0 -= *(abs + rn)
:SUBA "r0, "^absaddr^", "^reg^"-" is op=0x2b & reg; ind_abs=0 & idx_ctrl=2 & ahigh & alow
    [ absaddr = (ahigh << 8) | alow; ] {
  reg = reg - 1;
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  local idx:2 = zext(reg);
  local m:1 = *[ram]:1 (ea + idx);
  sub8_set_flags(r0, m);
}

# Pre-decrement indirect: --rn; r0 -= *(*(abs) + rn)
:SUBA "r0, *"^absaddr^", "^reg^"-" is op=0x2b & reg; ind_abs=1 & idx_ctrl=2 & ahigh & alow
    [ absaddr = (ahigh << 8) | alow; ] {
  reg = reg - 1;
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  local base:2 = *[ram]:2 ea;
  local idx:2 = zext(reg);
  local m:1 = *[ram]:1 (base + idx);
  sub8_set_flags(r0, m);
}


## Logical operations

# EORZ reg: r0 ^= reg
# Encoding: 001000rr  ($20-$23)
:EORZ reg is op=0x08 & reg {
  eor8_set_cc(r0, reg);
}

# EORI,r v: reg ^= imm
# Encoding: 001001rr vvvvvvvv  ($24-$27)
:EORI reg, imm8 is op=0x09 & reg; imm8 {
  eor8_set_cc(reg, imm8:1);
}

# EORR,r rel: reg ^= *(rel)
# Encoding: 001010rr 0aaaaaaa  ($28-$2B, i=0)
:EORR reg, reladdr is op=0x0a & reg; ind=0 & rel7 [ reladdr = inst_next + rel7; ] {
  local ea:2 = inst_next + rel7;
  local m:1 = *[ram]:1 ea;
  eor8_set_cc(reg, m);
}

# EORR,r *rel: reg ^= *(*(rel))
# Encoding: 001010rr 1aaaaaaa  ($28-$2B, i=1)
