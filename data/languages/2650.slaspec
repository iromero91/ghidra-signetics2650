# ZBSR: zero branch to subroutine, relative.
# Encoding: 10111011 iaaaaaaa  ($BB)
# Target = signed displacement from address 0, masked to 13 bits (page bits cleared).

# BSNR,r rel: branch to subroutine on register non-zero, relative.
# Encoding: 011110rr iaaaaaaa  ($78-$7B)

# BSNR,r rel
:BSNR reg, RELDST is op=0x1e & reg; RELDST {
  if (reg == 0) goto <done>;
  call RELDST;
<done>
}

# BSNR,r *rel
:BSNR reg, RELINDDST is op=0x1e & reg; RELINDDST {
  if (reg == 0) goto <done>;
  call [RELINDDST];
<done>
}

# BSNA,r abs: branch to subroutine on register non-zero, absolute.
# Encoding: 011111rr ippaaaaa aaaaaaaa  ($7C-$7F)
# Taken calls use the encoded destination page and update the page latch.

# BSNA,r abs
:BSNA reg, BRABSDST is op=0x1f & reg; BRABSDST {
  if (reg == 0) goto <done>;
  call BRABSDST;
<done>
}

# BSNA,r *abs
:BSNA reg, BRABSINDDST is op=0x1f & reg; BRABSINDDST {
  if (reg == 0) goto <done>;
  call [BRABSINDDST];
<done>
}

# BSXA abs,r3: branch to subroutine indexed, absolute.
# Encoding: 10111111 ippaaaaa aaaaaaaa  ($BF)
# Unconditional; r3 always the index. The encoded page bits select the base
# page and also update the page latch.

# BSXA abs,r3
:BSXA absaddr",r3" is byte=0xbf; ind_abs=0 & idx_ctrl & ahigh & alow
    [ absaddr = (idx_ctrl << 13) | (ahigh << 8) | alow; ] {
  page_latch = idx_ctrl:1;
  local base:2 = (ahigh << 8) | alow;
  local target:2 = base + zext(r3);
  call [target];
}

# BSXA *abs,r3
:BSXA "*"^absaddr",r3" is byte=0xbf; ind_abs=1 & idx_ctrl & ahigh & alow
    [ absaddr = (idx_ctrl << 13) | (ahigh << 8) | alow; ] {
  page_latch = idx_ctrl:1;
  local ea:2 = (zext(page_latch:1) << 13) | (ahigh << 8) | alow;
  local base:2 = *[ram]:2 ea;
  local target:2 = base + zext(r3);
  call [target];
}

# ZBSR zero
:ZBSR ZERODST is byte=0xbb; ZERODST {
  call ZERODST;
}

# ZBSR *zero
:ZBSR ZEROINDDST is byte=0xbb; ZEROINDDST {
  call [ZEROINDDST];
}

# RETC,v: return from subroutine, conditional.
# Encoding: 000101vv  ($14-$17)
# Pops RAS and branches back when CC matches v; v=3 is unconditional.

:RETC "eq" is byte=0x14 {
  if (cc1 != 0) goto <done>;
  if (cc0 != 0) goto <done>;
  return [ras0];
<done>
}

:RETC "gt" is byte=0x15 {
  if (cc1 != 0) goto <done>;
  if (cc0 == 0) goto <done>;
  return [ras0];
<done>
}

:RETC "lt" is byte=0x16 {
  if (cc1 == 0) goto <done>;
  if (cc0 != 0) goto <done>;
  return [ras0];
<done>
}

:RETC "un" is byte=0x17 {
  return [ras0];
}

# RETE,v: return from subroutine and enable interrupts, conditional.
# Encoding: 001101vv  ($34-$37)
# Same as RETC but also clears II (interrupt inhibit) bit in PSU on return.

:RETE "eq" is byte=0x34 {
  if (cc1 != 0) goto <done>;
  if (cc0 != 0) goto <done>;
  ii = 0;
  return [ras0];
<done>
}

:RETE "gt" is byte=0x35 {
  if (cc1 != 0) goto <done>;
  if (cc0 == 0) goto <done>;
  ii = 0;
  return [ras0];
<done>
}

:RETE "lt" is byte=0x36 {
  if (cc1 == 0) goto <done>;
  if (cc0 != 0) goto <done>;
  ii = 0;
  return [ras0];
<done>
}

:RETE "un" is byte=0x37 {
  ii = 0;
  return [ras0];
}


## Input/output operations

# REDC,r: read control bus into register.
# Encoding: 001100rr  ($30-$33)
:REDC reg is op=0x0c & reg {
  local port:1 = 0;
  reg = io_read(port);
  set_cc(reg);
}

# REDD,r: read data bus into register.
# Encoding: 011100rr  ($70-$73)
:REDD reg is op=0x1c & reg {
  local port:1 = 1;
  reg = io_read(port);
  set_cc(reg);
}

# REDE,r v: read extended port into register.
# Encoding: 010101rr vvvvvvvv  ($54-$57)
:REDE reg, imm8 is op=0x15 & reg; imm8 {
  local port:1 = imm8:1;
  reg = io_read(port);
  set_cc(reg);
}

# WRTC,r: write register to control bus.
# Encoding: 110100rr  ($B0-$B3)
:WRTC reg is op=0x2c & reg {
  local port:1 = 0;
  io_write(port, reg);
}

# WRTD,r: write register to data bus.
# Encoding: 111100rr  ($F0-$F3)
:WRTD reg is op=0x3c & reg {
  local port:1 = 1;
  io_write(port, reg);
}

# WRTE,r v: write register to extended port.
# Encoding: 110101rr vvvvvvvv  ($D4-$D7)
:WRTE reg, imm8 is op=0x35 & reg; imm8 {
  local port:1 = imm8:1;
  io_write(port, reg);
}


## Program status operations

# SPSU: store PSU into r0, then CC reflects r0.
# Encoding: 00010010  ($12)
:SPSU is byte=0x12 {
  r0 = psu;
  set_cc(r0);
}

# SPSL: store PSL into r0, then CC reflects r0.
# Encoding: 00010011  ($13)
:SPSL is byte=0x13 {
  r0 = psl;
  set_cc(r0);
}

# LPSU: load PSU from r0, but only mutable PSU bits are affected.
# S (bit7) is preserved, bits4/3 are unassigned and remain 0.
# Encoding: 10010010  ($92)
:LPSU is byte=0x92 {
  local sense:1 = psu & 0x80;
  local mutable:1 = r0 & 0x67;
  psu = sense | mutable;
}

# LPSL: load PSL from r0 (includes CC bits from r0[7:6]).
# Encoding: 10010011  ($93)
:LPSL is byte=0x93 {
  local oldrs:1 = rs;
  psl = r0;
  local newrs:1 = (r0 >> 4) & 1;
  if (oldrs == newrs) goto <done>;
  swap_rs_banks();
<done>
}

# TPSU v: test PSU selective bits under mask.
# Encoding: 10110100 vvvvvvvv  ($B4)
:TPSU imm8 is byte=0xb4; imm8 {
  set_cc_test_under_mask(psu, imm8:1);
}

# TPSL v: test PSL selective bits under mask.
# Encoding: 10110101 vvvvvvvv  ($B5)
:TPSL imm8 is byte=0xb5; imm8 {
  set_cc_test_under_mask(psl, imm8:1);
}

# CPSU v: clear selected mutable PSU bits.
# Encoding: 01110100 vvvvvvvv  ($74)
:CPSU imm8 is byte=0x74; imm8 {
  local mask:1 = imm8:1 & 0x67;
  psu = psu & ~mask;
}

# CPSL v: clear selected PSL bits.
# Encoding: 01110101 vvvvvvvv  ($75)
:CPSL imm8 is byte=0x75; imm8 {
  local oldrs:1 = rs;
  local newpsl:1 = psl & ~imm8:1;
  psl = newpsl;
  local newrs:1 = (newpsl >> 4) & 1;
  if (oldrs == newrs) goto <done>;
  swap_rs_banks();
<done>
}

# PPSU v: set selected mutable PSU bits.
# Encoding: 01110110 vvvvvvvv  ($76)
:PPSU imm8 is byte=0x76; imm8 {
  local bits:1 = imm8:1 & 0x67;
  psu = psu | bits;
}

# PPSL v: set selected PSL bits.
# Encoding: 01110111 vvvvvvvv  ($77)
:PPSL imm8 is byte=0x77; imm8 {
  local oldrs:1 = rs;
  local newpsl:1 = psl | imm8:1;
  psl = newpsl;
  local newrs:1 = (newpsl >> 4) & 1;
  if (oldrs == newrs) goto <done>;
  swap_rs_banks();
<done>
}


## Compare and test operations

# COMZ reg: compare r0 against reg.
# Encoding: 111000rr  ($E0-$E3)
:COMZ reg is op=0x38 & reg {
  set_cc_compare(r0, reg);
}

# COMI,r v: compare reg against immediate.
# Encoding: 111001rr vvvvvvvv  ($E4-$E7)
:COMI reg, imm8 is op=0x39 & reg; imm8 {
  set_cc_compare(reg, imm8:1);
}

# COMR,r rel: compare reg against value at PC-relative address (direct).
# Encoding: 111010rr 0aaaaaaa  ($E8-$EB, i=0)
:COMR reg, reladdr is op=0x3a & reg; ind=0 & rel7 [ reladdr = inst_next + rel7; ] {
  local ea:2 = inst_next + rel7;
  local m:1 = *[ram]:1 ea;
  set_cc_compare(reg, m);
}

# COMR,r *rel: compare reg against value at PC-relative indirect address.
# Encoding: 111010rr 1aaaaaaa  ($E8-$EB, i=1)
:COMR reg, "*"^reladdr is op=0x3a & reg; ind=1 & rel7 [ reladdr = inst_next + rel7; ] {
  local ea:2 = inst_next + rel7;
  local ptr:2 = *[ram]:2 ea;
  local m:1 = *[ram]:1 ptr;
  set_cc_compare(reg, m);
}

# --- COMA (Compare Absolute) ---
# 3 bytes: 111011rr iccaaaaa aaaaaaaa  ($EC-$EF)
# idx_ctrl=0: compare reg against memory
# idx_ctrl=1/2/3: indexed mode, compare r0 against memory and reg is index register

# Non-indexed direct: compare rn with *(abs)
:COMA reg, absaddr is op=0x3b & reg; ind_abs=0 & idx_ctrl=0 & ahigh & alow
    [ absaddr = (ahigh << 8) | alow; ] {
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  local m:1 = *[ram]:1 ea;
  set_cc_compare(reg, m);
}

# Non-indexed indirect: compare rn with *(*(abs))
:COMA reg, "*"^absaddr is op=0x3b & reg; ind_abs=1 & idx_ctrl=0 & ahigh & alow
    [ absaddr = (ahigh << 8) | alow; ] {
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  local ptr:2 = *[ram]:2 ea;
  local m:1 = *[ram]:1 ptr;
  set_cc_compare(reg, m);
}

# Indexed-only direct: compare r0 with *(abs + rn)
:COMA "r0, "^absaddr^", "^reg is op=0x3b & reg; ind_abs=0 & idx_ctrl=3 & ahigh & alow
    [ absaddr = (ahigh << 8) | alow; ] {
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  local idx:2 = zext(reg);
  local m:1 = *[ram]:1 (ea + idx);
  set_cc_compare(r0, m);
}

# Indexed-only indirect: compare r0 with *(*(abs) + rn)
:COMA "r0, *"^absaddr^", "^reg is op=0x3b & reg; ind_abs=1 & idx_ctrl=3 & ahigh & alow
    [ absaddr = (ahigh << 8) | alow; ] {
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  local base:2 = *[ram]:2 ea;
  local idx:2 = zext(reg);
  local m:1 = *[ram]:1 (base + idx);
  set_cc_compare(r0, m);
}

# Pre-increment direct: ++rn; compare r0 with *(abs + rn)
:COMA "r0, "^absaddr^", "^reg^"+" is op=0x3b & reg; ind_abs=0 & idx_ctrl=1 & ahigh & alow
    [ absaddr = (ahigh << 8) | alow; ] {
  reg = reg + 1;
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  local idx:2 = zext(reg);
  local m:1 = *[ram]:1 (ea + idx);
  set_cc_compare(r0, m);
}

# Pre-increment indirect: ++rn; compare r0 with *(*(abs) + rn)
:COMA "r0, *"^absaddr^", "^reg^"+" is op=0x3b & reg; ind_abs=1 & idx_ctrl=1 & ahigh & alow
    [ absaddr = (ahigh << 8) | alow; ] {
  reg = reg + 1;
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  local base:2 = *[ram]:2 ea;
  local idx:2 = zext(reg);
  local m:1 = *[ram]:1 (base + idx);
  set_cc_compare(r0, m);
}

# Pre-decrement direct: --rn; compare r0 with *(abs + rn)
:COMA "r0, "^absaddr^", "^reg^"-" is op=0x3b & reg; ind_abs=0 & idx_ctrl=2 & ahigh & alow
    [ absaddr = (ahigh << 8) | alow; ] {
  reg = reg - 1;
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  local idx:2 = zext(reg);
  local m:1 = *[ram]:1 (ea + idx);
  set_cc_compare(r0, m);
}

# Pre-decrement indirect: --rn; compare r0 with *(*(abs) + rn)
:COMA "r0, *"^absaddr^", "^reg^"-" is op=0x3b & reg; ind_abs=1 & idx_ctrl=2 & ahigh & alow
    [ absaddr = (ahigh << 8) | alow; ] {
  reg = reg - 1;
  local ea:2 = ((inst_start >> 13) << 13) | (ahigh << 8) | alow;
  local base:2 = *[ram]:2 ea;
  local idx:2 = zext(reg);
  local m:1 = *[ram]:1 (base + idx);
  set_cc_compare(r0, m);
}

# TMI,r v: test under mask immediate.
# Encoding: 111101rr vvvvvvvv  ($F4-$F7)
# CC=EQ if all bits selected by mask are set; otherwise CC=LT.
:TMI reg, imm8 is op=0x3d & reg; imm8 {
  set_cc_test_under_mask(reg, imm8:1);
}
